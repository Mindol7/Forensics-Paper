KCI_OPEN_API_KEY=your_kci_open_api_key_here
KCI_OPEN_API_URL=https://open.kci.go.kr/po/openapi/openApiSearch.kci
SCOPUS_API_KEY=your_scopus_api_key_here
SCOPUS_API_ROOT=https://api.elsevier.com/content
REQUEST_TIMEOUT=30
KCI_PAGE_SIZE=100
KCI_MAX_PAGES=
KCI_START_YEAR=2022
KCI_END_YEAR=2026
KCI_RECENT_YEARS=5
KCI_MAX_WORKERS=4
# Target request rate (req/sec). The limiter self-tunes (AIMD): it halves on
# KCI throttling/slow-drip and recovers back toward this ceiling on healthy
# responses. Raise to go faster (capped at 4); lower if KCI keeps throttling.
KCI_RATE_LIMIT_RPS=2
KCI_ENABLE_SWEEP=true
KCI_SWEEP_MAX_WORKERS=1
KCI_KEYWORD_FILTER_ENGLISH_KEYWORDS_PATH=filters/keywords_en.json
KCI_BLACKLIST_PATH=filters/blacklist.txt
SCOPUS_PAGE_SIZE=25
SCOPUS_MAX_PAGES=
DATABASE_URL=sqlite:///papers.db
EXPORT_DIR=reports
SCOPUS_SUBJECT_CODE_ALLOWLIST_PATH=filters/scopus_subject_codes.json
SCOPUS_ABSTRACT_MAX_WORKERS=6
STATE_KEY_LAST_SUCCESS_AT=kci:last_success_at
STATE_KEY_SCOPUS_LAST_SUCCESS_AT=scopus:last_success_at
