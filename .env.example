KCI_SERVICE_KEY=your_kci_service_key_here
KCI_BASE_URL=https://apis.data.go.kr/B552540/KCIOpenApi/artiInfo/openApiM310List
SCOPUS_API_KEY=your_scopus_api_key_here
SCOPUS_API_ROOT=https://api.elsevier.com/content
REQUEST_TIMEOUT=120
KCI_PAGE_SIZE=10
KCI_MAX_PAGES=
SCOPUS_PAGE_SIZE=25
SCOPUS_MAX_PAGES=
DATABASE_URL=sqlite:///kci_pipeline.db
EXPORT_DIR=reports
KCI_EXTRA_TERMS=
# Source-scope collection. Prefer institution-level sweep and then filter by title/abstract.
# Verified draft IDs:
# - 한국디지털포렌식학회: INS000009412 (journal: SER000003109)
# - 한국정보보호학회: INS000000552 (journal: 001221)
# - 한국정보과학회: INS000001216 (journals include SER000004124, A00398, 002167)
# See kci_source_scopes.sample.json and docs/kci_scope_mapping_draft.md
KCI_SOURCE_SCOPES_JSON=[{"label":"한국디지털포렌식학회","insi_id":"INS000009412"},{"label":"한국정보보호학회","insi_id":"INS000000552"},{"label":"한국정보과학회","insi_id":"INS000001216"}]
# Papers from these scopes bypass title/abstract filtering entirely.
# Default intent: all papers from 한국디지털포렌식학회 are stored as-is.
KCI_ALWAYS_INCLUDE_INSI_IDS=INS000009412
KCI_ALWAYS_INCLUDE_SERE_IDS=SER000003109
KCI_ALWAYS_INCLUDE_SCOPE_LABELS=한국디지털포렌식학회,디지털포렌식연구
# Title / abstract relevance terms used after broad source collection.
KCI_RELEVANCE_TERMS=포렌식,디지털 포렌식,디지털포렌식,forensic,forensics,digital forensic,digital forensics,dfir
SCOPUS_SUBJECT_CODE_ALLOWLIST_PATH=filters/scopus_subject_codes.json
SCOPUS_THIRD_FILTER_KEYWORDS_PATH=filters/scopus_third_filter_keywords.json
SCOPUS_ABSTRACT_MAX_WORKERS=6
STATE_KEY_LAST_SUCCESS_AT=kci:last_success_at
STATE_KEY_SCOPUS_LAST_SUCCESS_AT=scopus:last_success_at
